INPUT INSTRUCTIONS

  TITLE:
  LCGA Trajectory Analysis - 4 Classes (No_Mum)
  DATA:
  FILE = "exposure_data_1_0fe6bcbf0b94e87e0bf33ffcb5013abe.dat";
  VARIABLE:
  NAMES = USUBJID LWOM1 LWOM2 LWOM3 LWOM4 LWOM5;
   MISSING=.;
     IDVARIABLE = USUBJID;
    CLASSES = c(4);
    USEVARIABLES = USUBJID LWOM1 LWOM2 LWOM3 LWOM4 LWOM5;
    CATEGORICAL = LWOM1 LWOM2 LWOM3 LWOM4 LWOM5;
  ANALYSIS:

        TYPE = MIXTURE;
        ESTIMATOR = MLR; ! Maximum Likelihood Robust for categorical data
        PROCESSORS = 4;
        STARTS = 500 100; ! 500 random starts, 100 optimized

  MODEL:
    %OVERALL%
    ! LCGA: estimate class probabilities for first 3 classes
    [c#1-c#3];
  OUTPUT:
  TECH11 TECH14 SAMPSTAT;
  SAVEDATA:
  FILE = savedata_4.dat; SAVE = CPROB;
  PLOT:
  TYPE = PLOT3; SERIES = LWOM1(0) LWOM2(1) LWOM3(2) LWOM4(3) LWOM5(4);



*** WARNING in OUTPUT command
  SAMPSTAT option is not available when all outcomes are censored, ordered
  categorical, unordered categorical (nominal), count or continuous-time
  survival variables.  Request for SAMPSTAT is ignored.
