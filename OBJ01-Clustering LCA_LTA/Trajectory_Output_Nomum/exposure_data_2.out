INPUT INSTRUCTIONS

  TITLE:
  LCGA Trajectory Analysis - 2 Classes (No_Mum)
  DATA:
  FILE = "exposure_data_1_afb79a575ba9c964cfe12ca49503552f.dat";
  VARIABLE:
  NAMES = USUBJID LWOM1 LWOM2 LWOM3 LWOM4 LWOM5 LWOM6 LWOM7 LWOM8 LWOM9 LWOM10;
   MISSING=.;
     IDVARIABLE = USUBJID;
    CLASSES = c(2);
    USEVARIABLES = USUBJID LWOM1 LWOM2 LWOM3 LWOM4 LWOM5 LWOM6 LWOM7 LWOM8 LWOM9 LWOM10;
    CATEGORICAL = LWOM1 LWOM2 LWOM3 LWOM4 LWOM5 LWOM6 LWOM7 LWOM8 LWOM9 LWOM10;
  ANALYSIS:

        TYPE = MIXTURE;
        ESTIMATOR = MLR; ! Maximum Likelihood Robust for categorical data
        PROCESSORS = 4;
        STARTS = 500 100; ! 500 random starts, 100 optimized

  MODEL:
    %OVERALL%
    ! LCGA: estimate class probabilities for first 1 classes
    [c#1-c#1];
  OUTPUT:
  TECH11 TECH14 SAMPSTAT;
  SAVEDATA:
  FILE = savedata_2.dat; SAVE = CPROB;



