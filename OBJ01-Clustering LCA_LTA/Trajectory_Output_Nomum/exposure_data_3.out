Mplus VERSION 9 (Mac)
MUTHEN & MUTHEN
12/12/2025   8:00 PM

INPUT INSTRUCTIONS

  TITLE:
  LCGA Trajectory Analysis - 3 Classes (No_Mum)
  DATA:
  FILE = "exposure_data_1_afb79a575ba9c964cfe12ca49503552f.dat";
  VARIABLE:
  NAMES = USUBJID LWOM1 LWOM2 LWOM3 LWOM4 LWOM5 LWOM6 LWOM7 LWOM8 LWOM9 LWOM10;
   MISSING=.;
     IDVARIABLE = USUBJID;
    CLASSES = c(3);
    USEVARIABLES = USUBJID LWOM1 LWOM2 LWOM3 LWOM4 LWOM5 LWOM6 LWOM7 LWOM8 LWOM9 LWOM10;
    CATEGORICAL = LWOM1 LWOM2 LWOM3 LWOM4 LWOM5 LWOM6 LWOM7 LWOM8 LWOM9 LWOM10;
  ANALYSIS:

        TYPE = MIXTURE;
        ESTIMATOR = MLR; ! Maximum Likelihood Robust for categorical data
        PROCESSORS = 4;
        STARTS = 500 100; ! 500 random starts, 100 optimized

  MODEL:
    %OVERALL%
    ! LCGA: estimate class probabilities for first 2 classes
    [c#1-c#2];
  OUTPUT:
  TECH11 TECH14 SAMPSTAT;
  SAVEDATA:
  FILE = savedata_3.dat; SAVE = CPROB;



*** WARNING in OUTPUT command
  SAMPSTAT option is not available when all outcomes are censored, ordered
  categorical, unordered categorical (nominal), count or continuous-time
  survival variables.  Request for SAMPSTAT is ignored.
*** WARNING
  Data set contains cases with missing on all variables.
  These cases were not included in the analysis.
