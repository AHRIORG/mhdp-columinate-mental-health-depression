TITLE: Manual 3-Class LCGA Trajectory Analysis (No Mother);

DATA: FILE = columinate_lcga_nomum_data.dat;

VARIABLE: 
  NAMES = USUBJID LWOM1 LWOM2 LWOM3 LWOM4 LWOM5 LWOM6 LWOM7 LWOM8 LWOM9 LWOM10;
  IDVARIABLE = USUBJID;
  CLASSES = c(3);
  
  USEVARIABLES = USUBJID LWOM1 LWOM2 LWOM3 LWOM4 LWOM5 LWOM6 LWOM7 LWOM8 LWOM9 LWOM10;
  CATEGORICAL = LWOM1 LWOM2 LWOM3 LWOM4 LWOM5 LWOM6 LWOM7 LWOM8 LWOM9 LWOM10;
  MISSING = .;

ANALYSIS:
  TYPE = MIXTURE;
  ESTIMATOR = MLR;
  PROCESSORS = 4;
  STARTS = 500 100;

MODEL:
  %OVERALL%
  ! Estimate class probabilities for classes 1 and 2
  [c#1-c#2];

OUTPUT: TECH11 TECH14 SAMPSTAT;

PLOT: TYPE = PLOT3; SERIES = LWOM1(0) LWOM2(1) LWOM3(2) LWOM4(3) LWOM5(4) LWOM6(0) LWOM7(1) LWOM8(2) LWOM9(3) LWOM10(4);

SAVEDATA: FILE = savedata_manual.dat; SAVE = CPROB;
